{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "运行 Server 服务",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "运行 GUI 服务",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/gui"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "构建前端 (GUI)",
            "type": "shell",
            "command": "npm run build",
            "options": {
                "cwd": "${workspaceFolder}/gui"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "启动开发环境 (热更新双端)",
            "dependsOn": [
                "运行 Server 服务",
                "运行 GUI 服务"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "启动托管环境 (一键构建并运行)",
            "dependsOn": [
                "构建前端 (GUI)",
                "运行 Server 服务"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "打包发布源码压缩包 (tar.gz)",
            "type": "shell",
            "command": "npm run pack-tar",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}